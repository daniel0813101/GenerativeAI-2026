{
  "model_name": "meta-llama/Llama-3.2-1B-Instruct",
  "dataset_csv": "../dataset/dataset.csv",
  "output_dir": "../saved_models/checkpoint",
  "use_kfold": false,
  "num_folds": 5,
  "kfold_split_path": "../saved_models/splits/default_kfold_5.json",
  "use_holdout_test": false,
  "split_path": "../saved_models/splits/default_holdout_split.json",
  "tuning_split_path": "../saved_models/splits/default_train_val_split.json",
  "batch_size": 8,
  "eval_batch_size": 4,
  "learning_rate": 5e-05,
  "num_epochs": 30,
  "weight_decay": 0.02,
  "warmup_ratio": 0.1,
  "label_smoothing": 0.1,
  "shuffle_option_augmentation": true,
  "option_order_ensemble": true,
  "num_option_order_permutations": 4,
  "early_stopping_patience": 40,
  "early_stopping_min_delta": 0.0,
  "max_length": 1024,
  "grad_accum_steps": 4,
  "val_ratio": 0.1,
  "test_ratio": 0.1,
  "seed": 456,
  "num_workers": 4,
  "use_lora": true,
  "lora_r": 16,
  "lora_alpha": 16,
  "lora_dropout": 0.1,
  "lora_target_modules": "q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
}