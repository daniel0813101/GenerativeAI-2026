{
  "model_name": "meta-llama/Llama-3.2-1B-Instruct",
  "dataset_csv": "../dataset/dataset.csv",
  "output_dir": "../saved_models/checkpoint",
  "batch_size": 4,
  "eval_batch_size": 4,
  "learning_rate": 2e-05,
  "num_epochs": 50,
  "weight_decay": 0.01,
  "warmup_ratio": 0.1,
  "max_length": 512,
  "grad_accum_steps": 8,
  "val_ratio": 0.1,
  "test_ratio": 0.1,
  "seed": 42,
  "num_workers": 4,
  "use_lora": true,
  "lora_r": 16,
  "lora_alpha": 32,
  "lora_dropout": 0.05,
  "lora_target_modules": "q_proj,v_proj"
}